{
  "name": "lostcity-map-editor",
  "version": "1.0.0",
  "description": "Lost City Map Editor — Electron + WebGL",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "gl-matrix": "^3.4.3"
  },
  "build": {
    "appId": "com.lostcity.mapeditor",
    "productName": "Lost City Map Editor",
    "files": [
      "dist/renderer/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist/app"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
